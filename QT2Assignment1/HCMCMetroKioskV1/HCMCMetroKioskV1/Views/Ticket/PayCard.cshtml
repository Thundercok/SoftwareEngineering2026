@@model HCMCMetroKioskV1.Models.Ticket
@@{
    Layout = "~/Views/Shared/_Layout.cshtml"; // Sử dụng Layout 900px chuẩn
    ViewData["Title"] = "Card Payment";
    var totalAmount = Model.Price * (Model.IsReturn ? 2 : 1) * Model.Quantity;
}

<style>
    /* ── ĐỒNG BỘ 900PX & DIỆT FLICKER ── */
    .pay-container {
        max-width: 900px; margin: 20px auto; padding: 0 20px;
        will-change: transform; transform: translateZ(0);
    }

    /* ── CARD READER MACHINE (PREMIUM LOOK) ── */
    .reader-machine {
        width: 320px; height: 380px; margin: 0 auto 30px;
        background: #1C1C1E; border-radius: 30px;
        display: flex; flex-direction: column; align-items: center;
        justify-content: space-around; padding: 30px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.3), inset 0 0 20px rgba(255,255,255,0.05);
        position: relative; overflow: hidden;
        border: 4px solid #2C2C2E;
    }

    /* Hiệu ứng sóng NFC nhấp nháy */
    .nfc-waves {
        display: flex; gap: 8px; margin-bottom: 10px;
    }
    .wave {
        width: 4px; height: 30px; background: #0082FB; border-radius: 2px;
        animation: wave-pulse 1.5s infinite ease-in-out;
    }
    .wave:nth-child(2) { animation-delay: 0.2s; }
    .wave:nth-child(3) { animation-delay: 0.4s; }
    .wave:nth-child(4) { animation-delay: 0.6s; }

    @@keyframes wave-pulse {
        0%, 100% { transform: scaleY(1); opacity: 0.3; }
        50% { transform: scaleY(1.5); opacity: 1; box-shadow: 0 0 15px #0082FB; }
    }

    .card-slot-dark {
        width: 220px; height: 10px; background: #000;
        border-radius: 5px; border: 1px solid #444;
        box-shadow: inset 0 2px 10px rgba(0,0,0,1);
    }

    .reader-label {
        color: #8E8E93; font-size: 12px; font-weight: 800;
        text-transform: uppercase; letter-spacing: 3px;
    }

    /* ── TICKET INFO ── */
    .pay-header { font-size: 34px; font-weight: 900; color: #1C1C1E; margin-bottom: 5px; text-align: center; }
    .pay-amount { font-size: 60px; font-weight: 900; color: #0082FB; margin-bottom: 30px; text-align: center; }

    .summary-grid {
        width: 520px; margin: 0 auto 30px;
        display: grid; grid-template-columns: 1fr 1fr; gap: 15px;
        background: #F2F2F7; padding: 25px; border-radius: 20px;
        text-align: left;
    }
    .sum-item .lbl { font-size: 12px; color: #8E8E93; font-weight: 700; text-transform: uppercase; }
    .sum-item .val { font-size: 18px; color: #1C1C1E; font-weight: 800; }

    /* ── OVERLAY ── */
    .processing-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(255,255,255,0.98); backdrop-filter: blur(10px);
        z-index: 10000; flex-direction: column; align-items: center; justify-content: center;
    }
    .processing-overlay.show { display: flex; }
    .spinner { width: 70px; height: 70px; border: 6px solid #F2F2F7; border-top-color: #0082FB; border-radius: 50%; animation: spin 1s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ── BUTTONS ── */
    .btn-group { width: 520px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
    .btn-action { padding: 20px; border-radius: 15px; border: none; font-size: 16px; font-weight: 800; cursor: pointer; transition: 0.2s; }
    .btn-back { background: #333; color: white; }
    .btn-sim { background: #34C759; color: white; }
</style>

<div class="pay-container">
    <div class="pay-header">Insert or Tap Card</div>
    <div class="pay-amount">@@totalAmount.ToString("N0")₫</div>

    <div class="reader-machine">
        <div class="nfc-waves">
            <div class="wave"></div><div class="wave"></div><div class="wave"></div><div class="wave"></div>
        </div>
        <div style="font-size: 80px;">💳</div>
        <div class="card-slot-dark"></div>
        <div class="reader-label">Contactless / Chip</div>
    </div>

    <div class="summary-grid">
        <div class="sum-item"><div class="lbl">Route</div><div class="val">@(Model.FromStation?.NameEn ?? "Ben Thanh") → @(Model.ToStation?.NameEn ?? "Station")</div></div>
        <div class="sum-item"><div class="lbl">Ticket Type</div><div class="val">@(Model.IsReturn ? "Round-trip" : "One-way")</div></div>
        <div class="sum-item"><div class="lbl">Quantity</div><div class="val">@Model.Quantity Ticket(s)</div></div>
        <div class="sum-item"><div class="lbl">Reference</div><div class="val">@Model.TicketCode</div></div>
    </div>

    <div class="btn-group">
        <form method="post" action="/Ticket/Cancel" style="width:100%">
            <input type="hidden" name="id" value="@Model.Id"/>
            <button type="submit" class="btn-action btn-back" style="width:100%">CANCEL</button>
        </form>

        <form method="post" action="/Ticket/ProcessPayment" style="width:100%">
            <input type="hidden" name="id" value="@Model.Id"/>
            <button type="submit" class="btn-action btn-sim" style="width:100%" onclick="showLoad()">SIMULATE TAP</button>
        </form>
    </div>
</div>

<div class="processing-overlay" id="loadOverlay">
    <div class="spinner"></div>
    <h2 style="margin-top:20px; font-weight:900;">Verifying Card...</h2>
    <p style="color:#8E8E93;">Please do not remove your card</p>
</div>

@@section Scripts {
    <script>
        function showLoad() {
            document.getElementById('loadOverlay').classList.add('show');
        }

        // Tự động hủy sau 60s nếu khách không quẹt thẻ (Đồng bộ với Layout)
        let timeLeft = 60;
        setInterval(() => {
            timeLeft--;
            if (timeLeft <= 0) {
                window.location.href = '/Ticket/Buy';
            }
        }, 1000);
    </script>
}