@{
Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <title>HCMC Metro - Payment Failed</title>
    <style>
        body {
            background-color: #8B7D7B; margin: 0; padding: 0;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; font-family: -apple-system, sans-serif;
        }
        .kiosk-screen {
            width: 500px; height: 95vh; background: #FFF;
            display: flex; flex-direction: column;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5);
            border-radius: 12px; overflow: hidden;
        }
        .kiosk-nav {
            padding: 25px; display: flex;
            justify-content: space-between; align-items: center;
            border-bottom: 1px solid #EEE;
        }
        .kiosk-logo { height: 40px; }
        .content {
            flex: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 40px; text-align: center; gap: 20px;
        }
        .fail-icon {
            width: 80px; height: 80px;
            background: #D0021B; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 8px 30px rgba(208,2,27,.35);
            animation: pop .4s cubic-bezier(0.175,0.885,0.32,1.275);
        }
        @@keyframes pop {
            from { transform: scale(0); opacity: 0; }
            to   { transform: scale(1); opacity: 1; }
        }
        .fail-icon svg {
            width: 40px; height: 40px; stroke: white;
            stroke-width: 3; fill: none;
            stroke-linecap: round;
        }
        .fail-title { font-size: 30px; font-weight: 900; color: #1C1C1E; }
        .fail-sub   { font-size: 16px; color: #8E8E93; line-height: 1.6; }
        .btn-retry {
            width: 100%; padding: 22px;
            background: #D0021B; color: white;
            border: none; border-radius: 18px;
            font-size: 22px; font-weight: 800;
            cursor: pointer; margin-bottom: 12px;
        }
        .btn-home {
            width: 100%; padding: 22px;
            background: #1C1C1E; color: white;
            border: none; border-radius: 18px;
            font-size: 22px; font-weight: 800;
            cursor: pointer;
        }
        .footer { padding: 16px 25px 24px; flex-shrink: 0; }
    </style>
</head>
<body>
<div class="kiosk-screen">
    <nav class="kiosk-nav">
        <div style="font-size:28px;">☰</div>
        <img src="~/images/logo.webp" class="kiosk-logo"/>
        <div style="font-size:24px;">🇬🇧</div>
    </nav>

    <div class="content">
        <div class="fail-icon">
            <svg viewBox="0 0 24 24">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </div>
        <div class="fail-title">Payment Failed</div>
        <div class="fail-sub">
            Something went wrong with your payment.<br>
            Please try again or choose a different method.
        </div>
    </div>

    <div class="footer">
        <button class="btn-retry" onclick="window.location.href='/Ticket/Buy'">
            Try Again
        </button>
        <button class="btn-home" onclick="window.location.href='/'">
            Back to Home
        </button>
    </div>
</div>
</body>
</html>