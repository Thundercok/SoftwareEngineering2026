<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] | HCMC Metro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: #E8EAF0;
        min-height: 100vh;
    }

    .kiosk-shell {
        width: 900px;
        min-height: 100vh;
        background: #FFFFFF;
        display: flex;
        flex-direction: column;
        margin: 0 auto;
        box-shadow: 0 0 60px rgba(0,0,0,0.18);
    }

    /* HEADER - LOGO CENTERED ABSOLUTE */
    .top-bar {
        background: #FFFFFF;
        border-bottom: 2px solid #E5E7EB;
        padding: 0 40px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }

    /* 3-Column system to force centering */
    .nav-col { flex: 1; display: flex; align-items: center; }
    .nav-left { justify-content: flex-start; gap: 20px; }
    .nav-center { justify-content: center; }
    .nav-right { justify-content: flex-end; gap: 30px; }

    .main-logo { height: 60px; width: auto; object-fit: contain; }
    .machine-info { font-size: 13px; font-weight: 700; color: #6B7280; letter-spacing: 1px; }

    .status-pill {
        display: flex; align-items: center; gap: 8px;
        background: #DCFCE7; color: #15803D;
        font-size: 12px; font-weight: 700;
        padding: 6px 14px; border-radius: 20px;
    }

    .dot { width: 8px; height: 8px; background: #16A34A; border-radius: 50%; }
    .pulse { animation: pulse-green 2s infinite; }

    /* Fix Razor @@ syntax for keyframes */
    @@keyframes pulse-green {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(22, 163, 74, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(22, 163, 74, 0); }
    }

    .top-clock { font-size: 24px; font-weight: 800; color: #1B2A4A; font-variant-numeric: tabular-nums; }

    .btn-staff {
        background: #1B2A4A; color: #FFFFFF;
        border: none; border-radius: 8px; padding: 10px 18px;
        font-size: 13px; font-weight: 700; cursor: pointer;
        transition: background 0.2s;
    }
    .btn-staff:hover { background: #D0021B; }

    /* BACK BAR */
    .back-bar { 
        padding: 12px 36px; 
        border-bottom: 1px solid #E5E7EB; 
        display: flex; align-items: center; gap: 12px; 
        background: #F3F4F6; 
    }
    .btn-back { 
        display: flex; align-items: center; gap: 6px; 
        background: #FFFFFF; border: 1px solid #E5E7EB; 
        border-radius: 8px; padding: 7px 14px; 
        font-size: 13px; font-weight: 600; color: #1B2A4A; 
        text-decoration: none; 
    }
    .page-content { flex: 1; overflow-y: auto; }
</style>

</head>
<body>
<div class="kiosk-shell">

    <header class="top-bar">
        <div class="nav-col nav-left">
            <div class="status-pill">
                <div class="dot pulse"></div> 
                <span>ONLINE</span>
            </div>
            <div class="machine-info">TVM-BT-001</div>
        </div>

        <div class="nav-col nav-center">
            <img src="~/images/logo.png" class="main-logo" alt="HCMC Metro">
        </div>

        <div class="nav-col nav-right">
            <div class="top-clock" id="topClock">00:00:00</div>
            <button class="btn-staff" onclick="alert('Calling staff...')">☎ STAFF</button>
        </div>
    </header>

    @if (ViewData["ShowBack"] != null)
    {
        <div class="back-bar">
            <a href="@(ViewData["BackUrl"] ?? "/")" class="btn-back">← Back</a>
            <div class="breadcrumb">@Html.Raw(ViewData["Breadcrumb"] ?? "")</div>
        </div>
    }

    <div class="page-content">
        @RenderBody()
    </div>

    @if (IsSectionDefined("BottomBar"))
    {
        <div class="bottom-bar">
            @await RenderSectionAsync("BottomBar", required: false)
        </div>
    }

</div>

<script>
    (function() {
        function tick() {
            document.getElementById('topClock').textContent = new Date().toLocaleTimeString('en-GB', { hour12: false });
        }
        tick(); 
        setInterval(tick, 1000);
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>