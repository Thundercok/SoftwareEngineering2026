<style>
    :root {
        --metro-blue: #1B2A4A;
        --metro-red: #D0021B;
        --bg-paper: #F4F1EA;
    }

    /* Đảm bảo trang Home chiếm trọn phần thân máy Kiosk */
    .home-container {
        position: relative;
        width: 100%;
        height: calc(100vh - 80px); /* Trừ đi chiều cao của Header */
        background: var(--bg-paper);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        padding: 60px 0;
    }

    /* Background Mini Metro - Ẩn bớt để không rối */
    .mini-metro-bg {
        position: absolute;
        inset: 0;
        z-index: 1;
        opacity: 0.6;
        filter: blur(1px);
    }

    .metro-path {
        fill: none;
        stroke-width: 10;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    /* Đoàn tàu chạy */
    .train-unit {
        animation: travel 15s infinite linear;
    }

    @@keyframes travel {
        from { offset-distance: 0%; }
        to { offset-distance: 100%; }
    }

    /* Nội dung chính */
    .main-content {
        position: relative;
        z-index: 10;
        text-align: center;
    }

    .logo-hero {
        width: 420px;
        filter: drop-shadow(0 10px 20px rgba(0,0,0,0.1));
    }

    /* Footer area */
    .home-footer {
        position: relative;
        z-index: 10;
        width: 100%;
        padding: 0 40px;
    }

    .lang-switch {
        display: inline-flex;
        background: rgba(255, 255, 255, 0.8);
        padding: 4px;
        border-radius: 50px;
        margin-bottom: 25px;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .lang-btn {
        font-size: 14px;
        font-weight: 800;
        padding: 10px 24px;
        border-radius: 40px;
        border: none;
        background: transparent;
        color: var(--metro-blue);
        opacity: 0.4;
        cursor: pointer;
    }

    .lang-btn.active {
        background: #fff;
        opacity: 1;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .btn-get-started {
        background: var(--metro-red);
        color: white;
        border-radius: 16px;
        padding: 22px;
        font-size: 24px;
        font-weight: 800;
        text-transform: uppercase;
        text-decoration: none;
        display: block;
        box-shadow: 0 15px 30px rgba(208, 2, 27, 0.2);
    }
</style>

<div class="home-container">
    <div class="mini-metro-bg">
        <svg width="100%" height="100%" viewBox="0 0 540 800">
            <path id="path1" class="metro-path" d="M-50,300 L200,300 L350,450 L600,450" stroke="rgba(21, 101, 192, 0.2)"/>
            <path id="path2" class="metro-path" d="M150,850 L150,500 L400,250 L400,-50" stroke="rgba(208, 2, 27, 0.2)"/>
            
            <rect width="18" height="10" fill="var(--metro-blue)" class="train-unit" style="offset-path: path('M-50,300 L200,300 L350,450 L600,450');"/>
            <rect width="18" height="10" fill="var(--metro-red)" class="train-unit" style="offset-path: path('M150,850 L150,500 L400,250 L400,-50'); animation-delay: -7s;"/>

            <circle fill="#fff" stroke="#333" stroke-width="2" cx="200" cy="300" r="8" />
            <rect fill="#fff" stroke="#333" stroke-width="2" x="340" y="440" width="16" height="16" />
        </svg>
    </div>

    <div class="main-content">
        <img src="/images/logo.png" class="logo-hero" alt="HCMC Metro">
    </div>

    <div class="home-footer">
        <div class="lang-switch">
            <button class="lang-btn active">EN</button>
            <button class="lang-btn">VI</button>
        </div>
        <a href="/Ticket/Buy" class="btn-get-started">Get Started</a>
    </div>
</div>