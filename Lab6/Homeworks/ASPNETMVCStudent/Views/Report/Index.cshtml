@model ASPNETMVCStudent.Models.CourseReportViewModel

@{
    ViewData["Title"] = "Student Report";
}

<div class="container mt-4">
    <h2 class="mb-4">Student Enrollment Report</h2>

    <div class="card mb-4 d-print-none"> <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label class="col-form-label"><strong>Select Course:</strong></label>
                </div>
                <div class="col-auto">
                    <select asp-for="SelectedCourseId" asp-items="Model.Courses" class="form-select">
                        <option value="">-- Choose a Course --</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Generate Report</button>
                    <button type="button" class="btn btn-secondary ms-2" onclick="window.print()">Export to PDF</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.StudentsInCourse != null && Model.StudentsInCourse.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0">Enrolled Students: @Model.StudentsInCourse.First().Course.Title</h4>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Student ID</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Grade</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.StudentsInCourse)
                        {
                            <tr>
                                <td>@item.Student.StudentId</td>
                                <td>@item.Student.FirstName</td>
                                <td>@item.Student.LastName</td>
                                <td>@item.Grade</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (Model.SelectedCourseId != 0)
    {
        <div class="alert alert-warning">No students found for this course.</div>
    }
</div>