@model IEnumerable<StudentsApp.Models.tblStudents>

@{
    ViewData["Title"] = "Student List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@ViewData["Title"]</h2>
        <a asp-action="Create" class="btn btn-primary">Add New Student</a>
    </div>

    <table class="table table-striped table-hover border">
        <thead class="table-dark">
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th class="text-center">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.Email</td>
                <td class="text-center">
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Edit" asp-route-id="@item.StudentId" class="btn btn-outline-secondary">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.StudentId" class="btn btn-outline-info">View</a>
                        <a asp-action="Delete" asp-route-id="@item.StudentId" class="btn btn-outline-danger">Delete</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>