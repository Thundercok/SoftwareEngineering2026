@page
@model WindowsFormApp.Pages.LoginFormModel
@{
    ViewData["Title"] = "Login Form";
}

<h2>Login - Student Management</h2>

<form method="post">
    <div>
        <label>Username:</label>
        <input type="text" asp-for="Username" required />
    </div>
    <br />
    <div>
        <label>Password:</label>
        <input type="password" asp-for="Password" required />
    </div>
    <br />
    <button type="submit">Login</button>
    <p style="color:red; font-weight:bold;">@Model.ErrorMessage</p>
</form>

<p>Developed by Huynh Nhat Huy</p>