@page
@model WindowsFormApp.Pages.EnrollmentModel
<h2>Student Enrollments</h2>

<form method="get">
    <label>Select Course:</label>
    <select name="SelectedCourseID" onchange="this.form.submit()" asp-for="SelectedCourseID">
        <option value="">-- Select a Course --</option>
        @foreach(var c in Model.Courses) {
            <option value="@c.Key">@c.Value</option>
        }
    </select>
</form>

<hr />

@if (Model.SelectedCourseID > 0) {
    <h4>Students enrolled in this course:</h4>
    <form method="post" asp-page-handler="Add">
        <input type="hidden" name="CourseID" value="@Model.SelectedCourseID" />
        <input type="number" name="StudentID" placeholder="Enter Student ID to Enroll" required />
        <button type="submit">Enroll Student</button>
    </form>

    <table border="1" style="width:100%; margin-top:10px;">
        <tr><th>Student ID</th><th>Action</th></tr>
        @foreach(var row in Model.Enrollments) {
            <tr>
                <td>@row["StudentID"]</td>
                <td>
                    <form method="post" asp-page-handler="Delete">
                        <input type="hidden" name="StudentID" value="@row["StudentID"]" />
                        <input type="hidden" name="CourseID" value="@Model.SelectedCourseID" />
                        <button type="submit">Remove</button>
                    </form>
                </td>
            </tr>
        }
    </table>
}